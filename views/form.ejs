<div class="form-container">
    <div class="form-header">
        <h2>Contact Us</h2>
        <p>We'd love to hear from you!</p>
    </div>
    <% if (msg) { %>
        <p class="message <%= String(msg).includes('successfully') ? 'message-success' : 'message-error' %>">
            <%= msg %>
        </p>
    <% } %>
    <form action="/submit" method="POST" class="contact-form">
        <div class="form-group">
            <label for="name">Name:</label>
            <input type="text" id="name" name="txtname" class="form-control" required autofocus>
        </div>
        <div class="form-group">
            <label for="email">Email:</label>
            <input type="email" id="email" name="txtemail" class="form-control" required>
        </div>
        <div class="form-group">
            <label for="mob">Mobile:</label>
            <input type="tel" id="mob" name="txtmob" class="form-control" required>
        </div>
        <div class="form-group">
            <label for="subject">Subject:</label>
            <input type="text" id="subject" name="txtsubject" class="form-control" required>
        </div>
        <div class="form-group">
            <label for="message">Message:</label>
            <textarea id="message" name="txtmessage" rows="5" class="form-control" required></textarea>
        </div>
        <div class="button-group">
            <button type="submit" class="btn-submit">Send Message</button>
            <% if (msg && msg.length > 0) { %>
                <button type="button" class="btn-clear" onclick="window.location.href='/form'">Clear Message</button>
            <% } %>
        </div>
    </form>
</div>